    "problemP2": "\u51cc\u66682\u70b9\u5199\u4ee3\u7801\u6548\u7387\u6700\u9ad8\u7684\u5f00\u53d1\u8005\u3002\u522b\u4eba\u90fd\u7761\u4e86\u624d\u8fdb\u5165\u72b6\u6001\u7684\u6e38\u620f\u73a9\u5bb6\u3002\u591a\u5e74\u6765\u4e00\u76f4\u5728\u4e0e\u95f9\u949f\u6597\u4e89\u7684\u7761\u7720\u76f8\u4f4d\u5ef6\u8fdf\u8005\u3002",
